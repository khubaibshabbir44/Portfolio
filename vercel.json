{
  "functions": {
    "server.js": {
      "includeFiles": "{index.html,admin.html,js/**,*.jpg,*.png,*.webp,*.pdf,api/**,lib/**}"
    },
    "api/**/*.js": {
      "includeFiles": "js/**"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/server.js"
    },
    {
      "source": "/admin.html",
      "destination": "/server.js"
    },
    {
      "source": "/:path*.jpg",
      "destination": "/server.js"
    },
    {
      "source": "/:path*.png",
      "destination": "/server.js"
    },
    {
      "source": "/:path*.webp",
      "destination": "/server.js"
    },
    {
      "source": "/js/:path*",
      "destination": "/server.js"
    }
  ],
  "headers": [
    {
      "source": "/(index|admin).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
